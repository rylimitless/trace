# Database connection (overridden by compose for the app service)
DATABASE_URL=postgresql+psycopg://trace:trace@db:5432/trace

# Secret used to sign session cookies / tokens
SESSION_SECRET=dev-secret-change-me

# OpenRouter API key for the primary model
OPENROUTER_API_KEY=

# Default OpenRouter model id (e.g. "anthropic/claude-3.5-sonnet")
OPENROUTER_MODEL=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# OpenRouter model used for justification/explanation pass
LLM_JUSTIFICATION_MODEL=
